# ─────────────────────────────────────────────────────────────
# dev-quote-builder  환경변수 템플릿 (커밋용 — 실제 시크릿 금지)
# 복사 → .env 로 만들고 값 채우기. .env 는 gitignore됨.
# ─────────────────────────────────────────────────────────────

# ── Plan 1: DB ──────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ── Plan 3: 인증 (Auth.js + 카카오) ─────────────────────────
# AUTH_SECRET 생성:  openssl rand -base64 32
AUTH_SECRET=
AUTH_URL="http://localhost:3000"            # 배포 시 https://도메인
# developers.kakao.com → REST API 키 / Client Secret
# Redirect URI: http://localhost:3000/api/auth/callback/kakao
AUTH_KAKAO_ID=
AUTH_KAKAO_SECRET=

# ── Plan 4: AI 요구사항 정리기 (교내 mindlogic, 서버사이드 전용) ──
MINDLOGIC_API_KEY=
MINDLOGIC_BASE_URL="https://factchat-cloud.mindlogic.ai/v1/gateway"   # Anthropic 호환이면 /claude
# AI rate limit (grill 확정 시작값)
AI_LIMIT_USER_DAY=10
AI_LIMIT_USER_MIN=3
AI_LIMIT_IP_DAY=20
AI_INPUT_CHAR_CAP=1000
AI_OUTPUT_MAX_TOKENS=1500
AI_GLOBAL_KILL_DAY=200

# ── Plan 5: 알림 (Resend 메일 + Telegram 핑) ────────────────
RESEND_API_KEY=
RESEND_FROM="onboarding@resend.dev"          # 도메인 인증 전 기본 발신주소
ADMIN_EMAIL=                                  # 리드 알림 받을 운영자 이메일
TELEGRAM_BOT_TOKEN=                           # 기존 hermes 봇 재사용
TELEGRAM_CHAT_ID=

# ── Plan 6: 배포 백업 (Litestream → R2/S3) ──────────────────
# 앱이 직접 읽지 않음. litestream.yml에서 참조. 배포 단계서 채움.
LITESTREAM_ACCESS_KEY_ID=
LITESTREAM_SECRET_ACCESS_KEY=
LITESTREAM_BUCKET=
# 참고: Cloudflare 터널 토큰은 .env 아님 → lab-server docker-compose에 주입
